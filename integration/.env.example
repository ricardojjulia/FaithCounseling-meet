# ── Jitsi Meet integration ────────────────────────────────────────────────────
# Domain where FaithCounseling-meet is deployed (no protocol, no trailing slash)
JITSI_DOMAIN=meet.faithcounseling.app

# Application credentials — must match the Prosody JWT plugin config
JITSI_APP_ID=faithcounseling
JITSI_APP_SECRET=change-me-to-a-long-random-secret

# JWT token lifetime in seconds (default: 7200 = 2 hours)
JITSI_TOKEN_TTL=7200

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# The web app reads this at build time to embed the domain in the JS bundle
VITE_JITSI_DOMAIN=meet.faithcounseling.app
